{
  "name": "jskos-provider",
  "version": "0.1.0",
  "description": "Access JSKOS data with a uniform API",
  "type": "module",
  "files": [
    "lib",
    "errors",
    "utils",
    "providers"
  ],
  "scripts": {
    "test": "mocha --recursive",
    "lint": "eslint",
    "fix": "eslint --fix",
    "lint-staged": "lint-staged",
    "docs": "jsdoc -c jsdoc.json",
    "yesno": "node -e \"const yesno = require('yesno'); yesno({ question: 'Are you sure you want to continue?' }).then(ok => process.exit(ok ? 0 : 1));\"",
    "release": "test $(git rev-parse --abbrev-ref HEAD) = dev && git pull && npm test && npm version $SEMVER && npm run --silent yesno && (git push && git checkout main && git merge dev && git push --follow-tags && git checkout dev) || (git tag -d $(git describe --tags) && git reset --hard HEAD~1)",
    "release:patch": "SEMVER=patch npm run release",
    "release:minor": "SEMVER=minor npm run release",
    "release:major": "SEMVER=major npm run release",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "**/.*.js": [
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gbv/jskos-provider.git"
  },
  "author": "Jakob Voß",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gbv/jskos-provider/issues"
  },
  "homepage": "https://github.com/gbv/jskos-provider#readme",
  "devDependencies": {
    "axios-mock-adapter": "^2.1.0",
    "clean-jsdoc-theme": "^4.3.0",
    "eslint": "~9.39",
    "eslint-config-gbv": "~2.7",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "jsdoc": "^4.0.4",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.2.7",
    "mocha": "^11.0.1",
    "yesno": "^0.4.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "flexsearch": "~0.8.0",
    "jskos-tools": "^1.0.43",
    "localforage": "^1.10.0",
    "lodash": "^4.17.21",
    "uuid": "^13.0.0"
  }
}
